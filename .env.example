# ─── StudyFlow.ai Backend Config ───

FLASK_SECRET_KEY=change-this-to-a-random-string

# Google OAuth2
# 1. https://console.cloud.google.com → APIs & Services → Credentials
# 2. Create OAuth 2.0 Client ID (Web application)
# 3. Add redirect URI: http://localhost:5000/auth/callback
# 4. Download JSON → save as client_secret.json in this folder
GOOGLE_CLIENT_SECRETS=client_secret.json
OAUTH_REDIRECT_URI=http://localhost:5000/auth/callback

# Gemini AI (free)
# Get your key at: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Frontend
FRONTEND_URL=http://localhost:5173
